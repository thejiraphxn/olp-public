DATABASE_URL=postgresql://olp:olp@localhost:5432/olp
PORT=4000
CORS_ORIGIN=http://localhost:3000

JWT_SECRET=
JWT_EXPIRES_IN=7d

S3_ENDPOINT=http://localhost:9000
PUBLIC_S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=olp-recordings
S3_FORCE_PATH_STYLE=true

# === Whisper handoff ===
# Phase 2: Python whisper-server owns transcribe + summarize.
# Use 127.0.0.1 (not localhost) to force IPv4 — Python uvicorn binds
# 0.0.0.0 IPv4 only and Node 20+ resolves localhost to ::1 first.
WHISPER_API_BASE_URL=http://127.0.0.1:8000/v1
# Empty since whisper-server has WHISPER_SERVER_API_KEY blank (auth disabled).
# Set to match if you turn on shared-secret auth on the Python side.
WHISPER_API_KEY=
