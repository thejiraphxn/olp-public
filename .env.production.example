# Copy to .env.production and fill in. Never commit .env.production.
#
# Generate strong values:
#   openssl rand -base64 32 | tr -d '=+/'         # for passwords
#   openssl rand -base64 64 | tr -d '\n'          # for JWT_SECRET

# === Postgres (in-docker) ===
POSTGRES_USER=olp
POSTGRES_PASSWORD=olp
POSTGRES_DB=olp

# === MinIO / S3 (in-docker) ===
# These also serve as the S3 access/secret credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=olp-recordings

# === Auth ===
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# === Frontend / Socket.IO ===
# Leave empty for same-origin (browser → /socket.io/ → nginx → web → api).
# If the live class won't connect, set this to your full HTTPS origin so the
# browser opens the WebSocket directly against nginx instead of going through
# the Next.js rewrite. Cookie still rides because it's same domain.
#   NEXT_PUBLIC_SOCKET_URL=https://trsonline.mithat.co.th
NEXT_PUBLIC_SOCKET_URL=

# === Whisper handoff ===
# Phase 2 architecture: Python whisper-server owns transcribe + summary
# end-to-end. The Node API only needs to know how to reach it; Python
# writes to Postgres directly.
#
# Run whisper-server with:
#   cd whisper-server && python3 -m venv venv && source venv/bin/activate
#                     && pip install -r requirements.txt && python server.py
#
# host.docker.internal resolves to the VPS host from inside the api
# container (compose sets extra_hosts: host-gateway).
WHISPER_API_KEY=local
WHISPER_API_BASE_URL=http://host.docker.internal:8000/v1
# Short timeout — Node only waits for HTTP 202 from the handoff;
# Python's BackgroundTasks does the long work after.
WHISPER_HANDOFF_TIMEOUT_MS=60000

# === LLM ===
# LLM credentials live in whisper-server/.env now. The Node API does
# NOT make LLM calls in Phase 2.

# === FFmpeg tuning ===
# 16-core VPS — can afford slower preset for better quality. Drop to ultrafast
# under load.
FFMPEG_PRESET=veryfast
FFMPEG_CRF=23

# === Operational ===
# Set to false after the first successful deploy seeds demo data
# (saves ~3s on container restart).
SEED_ON_BOOT=true

# === MinIO storage path ===
# Where MinIO stores objects on the HOST filesystem (not inside the
# Docker volume). Lets operators inspect / back up / copy mp4 + mp3
# files directly with `cp` instead of `docker cp`.
#
# Layout that ends up on disk:
#   $OLP_DATA_DIR/minio/olp-recordings/processed/<sessionId>/playback.mp4
#                                              /audio.mp3
#                                              /thumb.jpg
#                                       /raw/<sessionId>/<ts>.webm
#
# Default "./data" is relative to the compose file. Set an absolute
# path on prod (e.g. /opt/live-stream/data).
#
# OLP_DATA_UID / GID must match the host user that owns OLP_DATA_DIR
# so MinIO can write — `id -u` / `id -g` of the deploy user.
OLP_DATA_DIR=/opt/live-stream/data
OLP_DATA_UID=1000
OLP_DATA_GID=1000
