# Copy to .env and edit. The server picks these up via os.getenv at boot.

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
# Comma-separated list, or * for permissive (matches the backend's CORS_ORIGIN style).
CORS_ORIGIN=*

# --- Model ---
# large-v3      — best quality, ~3 GB RAM at int8 / ~5 GB at float16
# medium        — good quality, ~1.2 GB at int8 (use this if low RAM)
# small         — light, fast, lower accuracy especially for non-English
WHISPER_MODEL_SIZE=medium
# int8 (CPU/low-RAM, default), float16 (GPU), int8_float16 (mixed)
WHISPER_COMPUTE_TYPE=int8
# auto | cpu | cuda
WHISPER_DEVICE=auto
# Optional override; leave blank to use ~/.cache/faster-whisper
WHISPER_MODEL_CACHE=

# --- Transcription tuning ---
# Cap parallel inferences in this process. RAM is the constraint; each
# in-flight request adds ~500 MB on top of the model itself.
WHISPER_MAX_CONCURRENT=4
# Reject uploads bigger than this (MB)
WHISPER_MAX_UPLOAD_MB=200
# Force a specific language. Leave blank to autodetect.
WHISPER_LANGUAGE=th
# Higher = better quality, slower. 5 is a sensible default.
WHISPER_BEAM_SIZE=2
# Set true to skip pre-loading and load lazily on first request.
WHISPER_LAZY_LOAD=false

# --- Auth (optional) ---
# If set, callers must send `Authorization: Bearer <key>`. Leave blank for
# local-only deployments.
WHISPER_SERVER_API_KEY=

# --- Scaling (advanced) ---
# Number of uvicorn worker processes. Each loads its own model copy, so
# RAM scales linearly. Keep at 1 unless the box has headroom or a GPU.
UVICORN_WORKERS=2

DATABASE_URL=postgresql+asyncpg://olp:olp@localhost:5432/olp

LLM_API_URL=https://ollama.com/v1
LLM_API_KEY=
LLM_MODEL=qwen3-next:80b-cloud
# Hard timeout per LLM call (seconds).
LLM_TIMEOUT_SECONDS=60

# --- Phase 2: Logging ---
# Rotating file handler — kept under whisper-server/.
APP_LOG_PATH=app.log
APP_LOG_MAX_BYTES=10485760
APP_LOG_BACKUP_COUNT=5

S3_ENDPOINT=http://localhost:9000
PUBLIC_S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=olp-recordings
S3_FORCE_PATH_STYLE=true

WHISPER_VAD_FILTER=true  
WHISPER_VAD_THRESHOLD=0.5   
WHISPER_VAD_MIN_SPEECH_MS=300 
WHISPER_VAD_MIN_SILENCE_MS=300

WHISPER_BATCHED=true
WHISPER_CPU_THREADS=8
WHISPER_NUM_WORKERS=3
WHISPER_MAX_CONCURRENT=3
WHISPER_BATCH_SIZE=12

# Reject task if /tmp has less than this many MB free.
WHISPER_MIN_FREE_DISK_MB=1024
# Hard cap on inference time (sec). If wmodel.transcribe() takes longer,
# task is marked FAILED so the next one isn't stuck behind it.
WHISPER_INFERENCE_TIMEOUT_SEC=1800

