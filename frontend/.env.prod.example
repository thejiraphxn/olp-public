# Copy to .env.prod and fill in for production builds.
# All three point at the deployed backend.

# Browser-side API base. Keep relative so requests go through Next.js → backend
# rewrite, which keeps cookies first-party.
NEXT_PUBLIC_API_BASE=/api/v1

# Browser-side Socket.IO endpoint. Use full HTTPS origin of the backend so the
# WebSocket upgrade bypasses Vercel/Next.js (which can't proxy WS).
NEXT_PUBLIC_SOCKET_URL=https://your-backend-host.example.com

# Server-side proxy target. Used by Next.js rewrites at runtime.
BACKEND_URL=https://your-backend-host.example.com
